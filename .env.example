# Example environment configuration for THE HATCH

# Stripe donation link. If empty, the donate button is disabled.
STRIPE_DONO_LINK=

# MongoDB connection URI. If empty, the app will run in guest‑only mode with no persistence.
MONGO_URI=

# Secret used for JWT signing or other cryptographic operations.
AUTH_SECRET=

# Credentials for the admin panel. If either is missing, the admin panel is disabled.
ADMIN_USER=
ADMIN_PASS=

# Cloudinary configuration. If any of these are missing, image uploads are disabled.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=